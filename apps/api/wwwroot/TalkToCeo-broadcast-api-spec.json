{
  "openapi": "3.0.1",
  "info": {
    "version": "1.0.0",
    "title": "Talk to CEO Broadcast API",
    "description": "Broadcast announcement API specification",
    "contact": {
      "name": "TalkToCeo Platform Team",
      "email": "platform@company.com"
    }
  },
  "servers": [
    {
      "url": "/v1",
      "description": "Production server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "parameters": {
      "client_id": {
        "name": "client_id",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "client_secret": {
        "name": "client_secret",
        "in": "header",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "broadcastId": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "integer"
        }
      }
    },
    "schemas": {
      "CreateBroadcastRequest": {
        "$ref": "./components/request/CreateBroadcastRequest.json"
      },
      "UpdateBroadcastRequest": {
        "$ref": "./components/request/UpdateBroadcastRequest.json"
      },
      "BroadcastResponse": {
        "$ref": "./components/response/BroadcastResponse.json"
      },
      "BroadcastReaderResponse": {
        "$ref": "./components/response/BroadcastReaderResponse.json"
      },
      "BroadcastReadSummaryResponse": {
        "$ref": "./components/response/BroadcastReadSummaryResponse.json"
      },
      "SuccessResponse": {
        "$ref": "./components/response/SuccessResponse.json"
      },
      "InvalidRequestResponse": {
        "$ref": "./components/response/InvalidRequestResponse.json"
      }
    }
  },
  "paths": {
    "/broadcasts": {
      "post": {
        "summary": "Create broadcast (CEO only)",
        "operationId": "createBroadcastAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/CreateBroadcastRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Broadcast created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Get broadcast list (CEO view)",
        "operationId": "getBroadcastsAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "name": "keyword",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "pageNumber",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 1
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 25
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Broadcast list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BroadcastResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/broadcasts/my": {
      "get": {
        "summary": "Get broadcast list (employee view)",
        "operationId": "getMyBroadcastsAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          }
        ],
        "responses": {
          "200": {
            "description": "Employee broadcast list retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BroadcastResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/broadcasts/{id}": {
      "put": {
        "summary": "Update broadcast",
        "operationId": "updateBroadcastAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "$ref": "#/components/parameters/broadcastId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/UpdateBroadcastRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Broadcast updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete broadcast",
        "operationId": "deleteBroadcastAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "$ref": "#/components/parameters/broadcastId"
          }
        ],
        "responses": {
          "200": {
            "description": "Broadcast deleted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "Get broadcast details",
        "operationId": "getBroadcastByIdAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "$ref": "#/components/parameters/broadcastId"
          }
        ],
        "responses": {
          "200": {
            "description": "Broadcast details retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BroadcastResponse"
                }
              }
            }
          }
        }
      }
    },
    "/broadcasts/{id}/sent": {
      "put": {
        "summary": "Send broadcast status update",
        "operationId": "sendStatusBroadcastAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "$ref": "#/components/parameters/broadcastId"
          }
        ],
        "responses": {
          "200": {
            "description": "The broadcast status has been successfully updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "403": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestResponse"
                }
              }
            }
          },
          "404": {
            "description": "Message not found"
          }
        }
      }
    },
    "/broadcasts/{id}/read": {
      "put": {
        "summary": "Mark broadcast as read",
        "operationId": "readBroadcastAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "$ref": "#/components/parameters/broadcastId"
          }
        ],
        "responses": {
          "200": {
            "description": "Marked as read",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/broadcasts/{id}/readers": {
      "get": {
        "summary": "Get broadcast readers",
        "operationId": "getBroadcastReadersAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "$ref": "#/components/parameters/broadcastId"
          }
        ],
        "responses": {
          "200": {
            "description": "Readers retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BroadcastReaderResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/broadcasts/{id}/read-summary": {
      "get": {
        "summary": "Get broadcast read summary",
        "operationId": "getBroadcastReadSummaryAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "$ref": "#/components/parameters/broadcastId"
          }
        ],
        "responses": {
          "200": {
            "description": "Summary retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BroadcastReadSummaryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/broadcasts/{id}/attachments/{attachmentId}": {
      "get": {
        "summary": "Download attachment",
        "operationId": "downloadAttachmentAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "attachmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Attachment downloaded successfully",
            "content": {
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "403": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestResponse"
                }
              }
            }
          },
          "404": {
            "description": "Attachment not found"
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "correlationId": "ABCD1234-1234-1234-1234-1234567890AB",
                  "error": {
                    "code": "E0001",
                    "userMessage": "Please contact support",
                    "developerMessage": "An unexpected error occurred"
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete attachment",
        "operationId": "deleteAttachmentAsync",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/client_id"
          },
          {
            "$ref": "#/components/parameters/client_secret"
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "attachmentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Attachment deleted successfully"
          },
          "403": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvalidRequestResponse"
                }
              }
            }
          },
          "404": {
            "description": "Attachment not found"
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                },
                "example": {
                  "correlationId": "ABCD1234-1234-1234-1234-1234567890AB",
                  "error": {
                    "code": "E0001",
                    "userMessage": "Please contact support",
                    "developerMessage": "An unexpected error occurred"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}